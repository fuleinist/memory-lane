{
  "name": "memory-lane",
  "version": "0.1.0",
  "description": "AI-powered CLI tool that automatically maintains a markdown journal of your coding work",
  "type": "module",
  "bin": {
    "memory-lane": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "git",
    "journal",
    "ai",
    "cli",
    "developer-tools"
  ],
  "license": "MIT"
}
